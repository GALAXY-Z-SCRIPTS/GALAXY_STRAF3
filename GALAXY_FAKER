table.insert(connections, UIS.InputBegan:Connect(function(input, processed)
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    local pressedKey = input.KeyCode
    local isBlacklisted = (pressedKey == Enum.KeyCode.W or pressedKey == Enum.KeyCode.A or pressedKey == Enum.KeyCode.S or pressedKey == Enum.KeyCode.D or pressedKey == Enum.KeyCode.Space or pressedKey == Enum.KeyCode.Slash or pressedKey == Enum.KeyCode.Escape)
    
    if isListeningForKey then
        isListeningForKey = false
        if not isBlacklisted then 
            ToggleKey = pressedKey 
            autoSaveProfile()
        end
        bindBtn.Text = ToggleKey.Name:upper()
        bindBtn.TextColor3 = ActiveTheme.Accent
    elseif isListeningForTermKey then
        isListeningForTermKey = false
        if not isBlacklisted then 
            TerminateKey = pressedKey 
            autoSaveProfile()
        end
        termBtn.Text = TerminateKey.Name:upper()
        termBtn.TextColor3 = ActiveTheme.Accent
    end
end))

-- // Configurations Profile Decoder Loader
if readfile and isfile and isfile(CONFIG_FILE) then
    pcall(function()
        local fileData = readfile(CONFIG_FILE)
        local decoded = HttpService:JSONDecode(fileData)
        if decoded then
            if decoded.Accent then ActiveTheme.Accent = Color3.new(decoded.Accent[1], decoded.Accent[2], decoded.Accent[3]) end
            if decoded.Nebula1 then ActiveTheme.Nebula1 = Color3.new(decoded.Nebula1[1], decoded.Nebula1[2], decoded.Nebula1[3]) end
            if decoded.Nebula2 then ActiveTheme.Nebula2 = Color3.new(decoded.Nebula2[1], decoded.Nebula2[2], decoded.Nebula2[3]) end
            
            if decoded.SavedKeybind then
                for _, enumKey in ipairs(Enum.KeyCode:GetEnumItems()) do
                    if enumKey.Value == decoded.SavedKeybind then ToggleKey = enumKey break end
                end
            end
            if decoded.SavedTerminateBind then
                for _, enumKey in ipairs(Enum.KeyCode:GetEnumItems()) do
                    if enumKey.Value == decoded.SavedTerminateBind then TerminateKey = enumKey break end
                end
            end
            if decoded.WindowSize then
                SavedSize = UDim2.new(0, decoded.WindowSize[1], 0, decoded.WindowSize[2])
            end
            if decoded.WindowPos then
                SavedPos = UDim2.new(decoded.WindowPos[1], decoded.WindowPos[2], decoded.WindowPos[3], decoded.WindowPos[4])
            end
            
            main.Size = SavedSize
            main.Position = SavedPos
        end
    end)
end

