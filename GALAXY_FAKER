-- // ADVANCED CORNER/EDGE RESIZING ENGINE
local resizeButton = Instance.new("ImageButton", main)
resizeButton.Size = UDim2.new(0, 20, 0, 20)
resizeButton.Position = UDim2.new(1, -20, 1, -20)
resizeButton.BackgroundTransparency = 1
resizeButton.Image = "rbxassetid://10214300067"
resizeButton.ImageColor3 = Color3.fromRGB(220, 40, 240)
resizeButton.ZIndex = 10

local MIN_WIDTH, MIN_HEIGHT = 400, 300
local resizing = false
local dragStartSize, dragStartPos

resizeButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = true
        dragStartSize = main.Size
        dragStartPos = input.Position
        
        local endCon
        endCon = input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then 
                resizing = false 
                endCon:Disconnect()
                SavedSize = main.Size
                autoSaveProfile()
            end
        end)
    end
end)

table.insert(connections, UIS.InputChanged:Connect(function(input)
    if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartPos
        local targetWidth = math.max(MIN_WIDTH, dragStartSize.X.Offset + delta.X)
        local targetHeight = math.max(MIN_HEIGHT, dragStartSize.Y.Offset + delta.Y)
        main.Size = UDim2.new(0, targetWidth, 0, targetHeight)
    end
end))

-- // STANDARD DRAGGING ENGINE LOGIC
local dragging, dragInput, dragStart, startPos
local function updateDrag(input)
    local delta = input.Position - dragStart
    main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

main.InputBegan:Connect(function(input)
    if not resizing and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        if input.Position.Y - main.AbsolutePosition.Y <= 70 then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
            
            local endCon
            endCon = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then 
                    dragging = false 
                    endCon:Disconnect()
                    SavedPos = main.Position
                    autoSaveProfile()
                end
            end)
        end
    end
end)

main.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
end)

table.insert(connections, UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then updateDrag(input) end
end))

