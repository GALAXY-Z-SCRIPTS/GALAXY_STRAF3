local function shiftInterfaceTheme(accentColor, nebulaColor1, nebulaColor2, skipSave)
    ActiveTheme.Accent = accentColor
    ActiveTheme.Nebula1 = nebulaColor1
    ActiveTheme.Nebula2 = nebulaColor2

    mainStroke.Color = accentColor
    ray1.BackgroundColor3 = nebulaColor1
    ray2.BackgroundColor3 = nebulaColor2
    imgLabel.ImageColor3 = nebulaColor1
    
    sliderFillGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, accentColor),
        ColorSequenceKeypoint.new(1, nebulaColor2)
    })
    
    placeholderLabel.TextColor3 = accentColor
    
    logoGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, accentColor),
        ColorSequenceKeypoint.new(0.5, nebulaColor2),
        ColorSequenceKeypoint.new(1, nebulaColor1)
    })
    
    fakerList.ScrollBarImageColor3 = accentColor
    themesList.ScrollBarImageColor3 = accentColor
    
    for _, uiElement in pairs(activePages) do
        if uiElement.page.Visible then
            uiElement.tabBtn.UIStroke.Color = accentColor
        end
    end

    if not skipSave then
        autoSaveProfile()
    end
end

