local function generateNavigationTab(tabTitle)
    local button = Instance.new("TextButton", tabSelectionContainer)
    button.Size = UDim2.new(0, 100, 1, 0)
    button.BackgroundColor3 = Color3.fromRGB(20, 12, 38)
    button.BackgroundTransparency = 0.3
    button.Text = tabTitle:upper()
    button.Font = Enum.Font.GothamBold
    button.TextColor3 = Color3.fromRGB(220, 180, 255)
    button.TextSize = 12
    button.ZIndex = 4
    
    Instance.new("UICorner", button).CornerRadius = UDim.new(0, 6)
    local bStroke = Instance.new("UIStroke", button)
    bStroke.Color = Color3.fromRGB(130, 60, 200)
    bStroke.Thickness = 1

    local pageFrame = Instance.new("Frame", pageDisplayContainer)
    pageFrame.Size = UDim2.new(1, 0, 1, 0)
    pageFrame.BackgroundTransparency = 1
    pageFrame.Visible = false
    pageFrame.ZIndex = 3

    button.MouseButton1Click:Connect(function()
        for _, uiElement in pairs(activePages) do 
            uiElement.page.Visible = false 
            uiElement.tabBtn.UIStroke.Color = Color3.fromRGB(130, 60, 200) 
        end
        pageFrame.Visible = true
        bStroke.Color = mainStroke.Color
    end)

    activePages[tabTitle] = { page = pageFrame, tabBtn = button }
    return pageFrame
end

